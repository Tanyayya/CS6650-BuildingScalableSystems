{
  "family": "kvdb-ll-1",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::989461485811:role/LabRole",
  "taskRoleArn": "arn:aws:iam::989461485811:role/LabRole",
  "containerDefinitions": [{
    "name": "kvdb-ll",
    "image": "989461485811.dkr.ecr.us-east-1.amazonaws.com/kvdb-ll:latest",
    "portMappings": [{"containerPort": 8080, "protocol": "tcp"}],
    "environment": [
      {"name": "PEERS", "value": "http://32.195.204.4:8080,http://98.92.69.134:8080,http://100.27.247.126:8080,http://44.220.54.46:8080"}
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {"awslogs-group": "/ecs/kvdb", "awslogs-region": "us-east-1", "awslogs-stream-prefix": "ll-1"}
    }
  }]
}
