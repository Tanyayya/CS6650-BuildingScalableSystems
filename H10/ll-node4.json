{
  "family": "kvdb-ll-node4",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::989461485811:role/LabRole",
  "taskRoleArn": "arn:aws:iam::989461485811:role/LabRole",
  "containerDefinitions": [{
    "name": "kvdb-ll",
    "image": "989461485811.dkr.ecr.us-east-1.amazonaws.com/kvdb-ll:latest",
    "portMappings": [{"containerPort": 8080, "protocol": "tcp"}],
    "environment": [
      {"name": "PEERS", "value": "http://44.192.253.214:8080,http://13.217.168.47:8080,http://44.211.116.76:8080,http://44.213.82.37:8080"}
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/kvdb",
        "awslogs-region": "us-east-1",
        "awslogs-stream-prefix": "ll-4"
      }
    }
  }]
}
